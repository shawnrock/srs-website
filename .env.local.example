# AI / Video / Speech APIs
GOOGLE_API_KEY=your_gemini_api_key_here
DAILY_API_KEY=your_daily_api_key_here
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# App base URL
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Email / SMTP (for candidate invite emails)
# Option A — Gmail SMTP (enable "App Passwords" in Google Account settings)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-16-char-app-password

# Option B — Office 365 / Outlook SMTP
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=noreply@srsinfoway.com
# SMTP_PASS=your-password

# From address shown to email recipients
SMTP_FROM=SRS Infoway AI Interview <noreply@srsinfoway.com>
